{
  "name": "dig",
  "version": "0.1.0",
  "description": "Local MCP server for querying construction finance data through an Agave-compatible interface.",
  "type": "module",
  "bin": {
    "dig": "./dist/src/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/src/server.js",
    "test": "TMPDIR=/tmp TMP=/tmp TEMP=/tmp vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=22"
  }
}
